---
import business from '../data/business.json';
import SocialIcons from './SocialIcons.astro';

const nav = [
  { href: '/', label: 'Anasayfa' },
  { href: '/hakkimizda', label: 'Hakkımızda' },
  { href: '/degerlerimiz', label: 'Değerlerimiz' },
  { href: '/ekibimiz', label: 'Ekibimiz' },
  { href: '/paketler', label: 'Paketler & Fiyatlar' },
  { href: '/iletisim', label: 'İletişim' },
];

const pathname = Astro.url.pathname;
const isActive = (href: string) => href === '/' ? pathname === '/' : pathname.startsWith(href);
---
<header class="sticky top-0 z-40 bg-white border-b border-zinc-200">

  {/* Üst bilgi şeridi — kurumsal, sessiz */}
  <div class="hidden sm:block bg-zinc-900 text-zinc-300 text-xs">
    <div class="max-w-7xl mx-auto px-6 h-9 flex items-center justify-between gap-4">
      <div class="flex items-center gap-5 text-[11px] tracking-wide">
        <span class="flex items-center gap-1.5 text-zinc-300"><span class="text-red-500">●</span> Edremit 5. Noterliği Karşısı</span>
        <span class="hidden md:flex items-center gap-1.5 text-zinc-400">Pzt-Cmt: 08:30-18:30</span>
      </div>
      <div class="flex items-center gap-4 text-[11px]">
        <a href={business.social.instagram} target="_blank" rel="noopener" class="text-zinc-400 hover:text-white transition-colors" aria-label="Instagram">
          <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
        </a>
        <a href={business.social.youtube} target="_blank" rel="noopener" class="text-zinc-400 hover:text-white transition-colors" aria-label="YouTube">
          <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="currentColor"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
        </a>
        <span class="text-zinc-700">|</span>
        <a href={`tel:${business.phoneE164}`} class="text-white hover:text-red-400 transition-colors font-medium tracking-wide">{business.phone}</a>
      </div>
    </div>
  </div>

  {/* Ana header — beyaz, kurumsal */}
  <div class="max-w-7xl mx-auto px-6 h-20 sm:h-24 flex items-center justify-between">

    {/* Sol — Logo + Marka */}
    <a href="/" class="flex items-center gap-4 group">
      <img src="/images/logo.jpeg" alt="Edremit Merkez Pilot Garage logo" class="h-16 w-16 sm:h-20 sm:w-20 rounded object-cover" width="80" height="80" />
      <div class="leading-tight">
        <div class="font-bold text-red-600 text-lg sm:text-xl tracking-tight group-hover:text-red-700 transition-colors">{business.name}</div>
        <div class="text-[10px] sm:text-[11px] text-zinc-500 uppercase tracking-[0.18em] mt-0.5 font-medium">Oto Ekspertiz <span class="text-red-600">·</span> TSE Belgeli</div>
      </div>
    </a>

    {/* Orta — Ana navigasyon (lg+) */}
    <nav class="hidden lg:flex items-center gap-1">
      {nav.map(item => (
        <a
          href={item.href}
          class={`relative px-4 py-2 text-[13px] uppercase tracking-[0.12em] font-semibold transition-colors group ${isActive(item.href) ? 'text-red-600' : 'text-zinc-700 hover:text-red-600'}`}
        >
          {item.label}
          <span class={`absolute left-4 right-4 -bottom-0.5 h-0.5 bg-red-600 transition-transform origin-left ${isActive(item.href) ? 'scale-x-100' : 'scale-x-0 group-hover:scale-x-100'}`}></span>
        </a>
      ))}
    </nav>

    {/* Sağ — CTA + Mobil buton */}
    <div class="flex items-center gap-2">
      <a
        href={`tel:${business.phoneE164}`}
        class="hidden sm:inline-flex items-center gap-2 px-4 py-2 bg-red-600 hover:bg-red-700 text-white text-sm font-semibold tracking-wide rounded transition-colors"
      >
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z"/></svg>
        <span class="hidden md:inline">Hemen Ara</span>
      </a>
      <button id="mobile-menu-btn" type="button" class="lg:hidden p-2 text-zinc-700 hover:text-red-600 transition-colors" aria-label="Menü">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
      </button>
    </div>
  </div>

  {/* Mobil menü */}
  <div id="mobile-menu" class="lg:hidden hidden border-t border-zinc-200 bg-white">
    <nav class="max-w-7xl mx-auto px-6 py-3 flex flex-col gap-1">
      {nav.map(item => (
        <a
          href={item.href}
          class={`px-3 py-3 text-sm font-semibold uppercase tracking-[0.1em] border-l-2 transition-colors ${isActive(item.href) ? 'text-red-600 border-red-600 bg-red-50/60' : 'text-zinc-700 border-transparent hover:text-red-600 hover:border-red-300 hover:bg-zinc-50'}`}
        >
          {item.label}
        </a>
      ))}
      <div class="mt-3 pt-3 border-t border-zinc-100 flex items-center justify-between">
        <span class="text-xs text-zinc-500 uppercase tracking-wide">Bizi Takip Edin</span>
        <SocialIcons size="sm" />
      </div>
    </nav>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });
</script>
