---
import business from '../data/business.json';

const reels = [
  { id: 'DXpLFixiG0a', title: 'Mor Işık Altında Gerçekler', caption: 'Gözle kusursuz görünebilir, ama mor (UV) ışık altında gerçekler saklanmaz.', highlight: true },
  { id: 'DXFQPXHiJ52', title: 'Boya Tespit Cihazı', caption: 'Profesyonel cihazlarımızla nokta atışı tespit ediyoruz.' },
  { id: 'DXHqCgCDSi6', title: 'Müşteri Deneyimi', caption: 'Edremit\'te ekspertiz için Pilot Garage tercih edilmesi gereken yer.' },
  { id: 'DXmgpuMiC3K', title: 'Motor Kontrolü', caption: 'Aracın kalbi olan motoru profesyonel ekipmanla detaylı inceliyoruz.' },
  { id: 'DXtoVVkCFRB', title: 'Conta Testi', caption: 'Conta gözle anlaşılmaz ama testle ortaya çıkar.' },
];
---
<section class="bg-zinc-50 py-16 sm:py-20 overflow-hidden">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-4 mb-8">
      <div>
        <div class="inline-block px-3 py-1 bg-gradient-to-r from-purple-100 to-pink-100 text-purple-700 text-xs font-bold uppercase tracking-wider rounded-full">
          📸 Instagram Reels
        </div>
        <h2 class="text-3xl sm:text-4xl font-bold text-zinc-900 mt-3">Hizmetlerimizi İzleyin</h2>
        <p class="mt-2 text-zinc-600">Gerçek ekspertiz çalışmalarımızı kendi gözlerinizle görün.</p>
      </div>
      <a
        href={business.social.instagram}
        target="_blank"
        rel="noopener"
        class="inline-flex items-center gap-2 px-4 py-2 bg-gradient-to-tr from-purple-600 via-pink-500 to-orange-400 hover:opacity-90 text-white font-semibold rounded-md text-sm transition-opacity self-start sm:self-auto"
      >
        Bizi Takip Edin
        <span>→</span>
      </a>
    </div>

    <div class="relative -mx-4 sm:-mx-6 px-4 sm:px-6">
      <div class="reels-scroller flex gap-4 overflow-x-auto pb-4 snap-x snap-mandatory scrollbar-thin">
        {reels.map(reel => (
          <article class={`reel-card flex-shrink-0 w-[260px] sm:w-[280px] snap-start group cursor-pointer ${reel.highlight ? 'ring-4 ring-purple-300 ring-offset-2 rounded-2xl' : ''}`} data-reel-id={reel.id}>
            <div class="relative aspect-[9/16] bg-zinc-900 rounded-2xl overflow-hidden shadow-lg">
              <video
                class="absolute inset-0 w-full h-full object-cover"
                muted
                loop
                playsinline
                preload="metadata"
                poster={`/reels/${reel.id}.jpg`}
              >
                <source src={`/reels/${reel.id}.mp4`} type="video/mp4" />
              </video>
              <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-transparent to-black/20"></div>

              <button class="absolute inset-0 flex items-center justify-center text-white group-hover:scale-110 transition-transform play-btn" aria-label="Oynat">
                <div class="w-14 h-14 bg-white/20 backdrop-blur-sm border border-white/40 rounded-full flex items-center justify-center">
                  <svg class="w-6 h-6 ml-1" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
                </div>
              </button>

              {reel.highlight && (
                <div class="absolute top-3 left-3 px-2 py-1 bg-purple-600 text-white text-xs font-bold rounded-full flex items-center gap-1">
                  <span class="w-1.5 h-1.5 bg-white rounded-full animate-pulse"></span>
                  UV TEKNOLOJİSİ
                </div>
              )}

              <div class="absolute bottom-0 inset-x-0 p-3 text-white">
                <div class="font-bold text-sm">{reel.title}</div>
                <p class="text-xs text-white/80 line-clamp-2 mt-0.5">{reel.caption}</p>
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>

    <p class="mt-4 text-center text-xs text-zinc-500">⬅ Yana kaydırarak tüm videoları görün ➡</p>
  </div>
</section>

<style>
  .reels-scroller { scroll-padding-left: 1rem; }
  .reels-scroller::-webkit-scrollbar { height: 6px; }
  .reels-scroller::-webkit-scrollbar-track { background: rgba(0,0,0,0.05); border-radius: 3px; }
  .reels-scroller::-webkit-scrollbar-thumb { background: rgba(0,0,0,0.25); border-radius: 3px; }
</style>

<script>
  document.querySelectorAll<HTMLElement>('.reel-card').forEach(card => {
    const video = card.querySelector('video');
    const btn = card.querySelector<HTMLButtonElement>('.play-btn');
    if (!video || !btn) return;
    let playing = false;
    btn.addEventListener('click', (e) => {
      e.preventDefault();
      if (playing) {
        video.pause();
        btn.style.opacity = '1';
      } else {
        document.querySelectorAll('video').forEach(v => v !== video && v.pause());
        document.querySelectorAll<HTMLElement>('.play-btn').forEach(b => b.style.opacity = '1');
        video.play();
        btn.style.opacity = '0';
      }
      playing = !playing;
    });
    video.addEventListener('ended', () => {
      btn.style.opacity = '1';
      playing = false;
    });
  });
</script>
