---
import business from '../data/business.json';
import reviewsData from '../data/reviews.json';

const reviews = reviewsData.reviews;
const tripled = [...reviews, ...reviews, ...reviews];
---
<section class="bg-white py-16 sm:py-20 overflow-hidden">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <div class="text-center max-w-2xl mx-auto mb-10">
      <div class="inline-flex items-center gap-3 mb-4">
        <div class="w-10 h-10 bg-white rounded-full flex items-center justify-center shadow-md ring-1 ring-zinc-200">
          <svg viewBox="0 0 24 24" class="w-6 h-6">
            <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
            <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84A11 11 0 0 0 12 23z"/>
            <path fill="#FBBC04" d="M5.84 14.09a6.6 6.6 0 0 1 0-4.18V7.07H2.18a11 11 0 0 0 0 9.86l3.66-2.84z"/>
            <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1A11 11 0 0 0 2.18 7.07l3.66 2.84C6.71 7.31 9.14 5.38 12 5.38z"/>
          </svg>
        </div>
        <div class="text-left">
          <div class="flex items-center gap-1.5">
            <span class="text-2xl font-bold text-zinc-900">{business.rating.value.toFixed(1)}</span>
            <span class="text-yellow-500 text-xl">★★★★★</span>
          </div>
          <div class="text-xs text-zinc-500">{business.rating.count}+ Google Yorumu</div>
        </div>
      </div>
      <h2 class="text-3xl sm:text-4xl font-bold text-zinc-900">Müşterilerimiz Ne Diyor?</h2>
      <p class="mt-3 text-zinc-600">Gerçek müşteri deneyimleri — tüm yorumları Google'da görebilirsiniz.</p>
    </div>

    <div class="reviews-marquee relative -mx-4 sm:-mx-6 px-4 sm:px-6">
      <div class="reviews-track flex gap-5 w-max">
        {tripled.map((review, idx) => (
          <article class="review-card flex-shrink-0 w-[300px] sm:w-[340px] bg-zinc-50 border border-zinc-200 rounded-xl p-5 shadow-sm">
            <div class="flex items-start justify-between mb-3">
              <div class="flex items-center gap-3">
                <div class="w-10 h-10 rounded-full bg-gradient-to-br from-red-500 to-red-700 text-white flex items-center justify-center font-bold">
                  {review.name.charAt(0)}
                </div>
                <div>
                  <div class="font-semibold text-zinc-900 text-sm">{review.name}</div>
                  <div class="text-xs text-zinc-500">{new Date(review.date).toLocaleDateString('tr-TR', { day: 'numeric', month: 'long', year: 'numeric' })}</div>
                </div>
              </div>
              <svg class="w-5 h-5 text-zinc-300" viewBox="0 0 24 24" fill="currentColor"><path d="M3 21l1.65-3.8a9 9 0 1 1 3.4 2.9L3 21z"/></svg>
            </div>
            <div class="flex gap-0.5 text-yellow-500 mb-2">
              {Array.from({ length: review.rating }).map(() => <span>★</span>)}
            </div>
            <p class="text-sm text-zinc-700 leading-relaxed line-clamp-5">{review.text}</p>
          </article>
        ))}
      </div>
    </div>

    <div class="mt-10 text-center">
      <a
        href={business.googleReviewsUrl}
        target="_blank"
        rel="noopener"
        class="inline-flex items-center gap-2 px-5 py-2.5 bg-zinc-900 hover:bg-zinc-800 text-white text-sm font-semibold rounded-md transition-colors"
      >
        🔍 Google'da Tüm Yorumları Gör
      </a>
    </div>
  </div>
</section>

<style>
  .reviews-marquee { mask-image: linear-gradient(to right, transparent, black 5%, black 95%, transparent); -webkit-mask-image: linear-gradient(to right, transparent, black 5%, black 95%, transparent); }
  .reviews-track {
    animation: scroll-x 40s linear infinite;
  }
  .reviews-marquee:hover .reviews-track { animation-play-state: paused; }
  @keyframes scroll-x {
    from { transform: translateX(0); }
    to { transform: translateX(calc(-100% / 3)); }
  }
  @media (prefers-reduced-motion: reduce) {
    .reviews-track { animation: none; }
  }
</style>
