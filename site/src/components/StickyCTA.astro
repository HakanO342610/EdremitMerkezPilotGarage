---
import business from '../data/business.json';
const waUrl = `https://wa.me/${business.whatsapp.replace('+','')}?text=${encodeURIComponent(business.whatsappMessage)}`;
---
<div class="md:hidden fixed bottom-0 inset-x-0 z-50 grid grid-cols-2 border-t border-zinc-200 shadow-2xl">
  <a href={`tel:${business.phoneE164}`} class="flex items-center justify-center gap-2 py-3.5 bg-red-600 text-white font-semibold text-sm active:bg-red-700">
    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z"/></svg>
    Ara
  </a>
  <a href={waUrl} target="_blank" rel="noopener" class="flex items-center justify-center gap-2 py-3.5 bg-green-600 text-white font-semibold text-sm active:bg-green-700">
    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347zM12.057 21.785c-1.832 0-3.628-.495-5.207-1.432l-.373-.221-3.873 1.015 1.034-3.778-.243-.387c-1.025-1.631-1.567-3.514-1.566-5.435.003-5.65 4.601-10.247 10.252-10.247 2.737.001 5.31 1.068 7.244 3.004 1.934 1.936 2.999 4.509 2.998 7.246-.003 5.65-4.602 10.235-10.266 10.235zm8.71-18.95C18.482 1.123 15.42 0 12.057 0 5.353 0 .003 5.35 0 11.97c0 2.104.553 4.16 1.604 5.97L0 24l6.305-1.654a11.882 11.882 0 005.681 1.448h.005c6.704 0 11.962-5.351 11.964-11.971.001-3.207-1.243-6.222-3.51-8.488z"/></svg>
    WhatsApp
