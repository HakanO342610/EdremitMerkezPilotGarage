---
import business from '../data/business.json';

const icons: Record<string, string> = {
  uv: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"/></svg>`,
  shield: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 12 2 2 4-4"/></svg>`,
  checklist: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="m9 11 3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>`,
  star: `<svg viewBox="0 0 24 24" fill="currentColor" stroke="none"><path d="M11.48 3.499a.562.562 0 0 1 1.04 0l2.125 5.111a.563.563 0 0 0 .475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 0 0-.182.557l1.285 5.385a.562.562 0 0 1-.84.61l-4.725-2.885a.562.562 0 0 0-.586 0L6.982 20.54a.562.562 0 0 1-.84-.61l1.285-5.386a.562.562 0 0 0-.182-.557l-4.204-3.602a.562.562 0 0 1 .321-.988l5.518-.442a.563.563 0 0 0 .475-.345L11.48 3.5Z"/></svg>`,
  map: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>`,
  wrench: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>`,
};

const featured = business.usps.find(u => u.featured)!;
const others = business.usps.filter(u => !u.featured);
---
<section class="bg-white py-16 sm:py-20">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <div class="text-center max-w-2xl mx-auto mb-12">
      <div class="inline-block px-3 py-1 bg-red-50 text-red-600 text-xs font-bold uppercase tracking-wider rounded-full">Neden Bizi Seçmelisiniz</div>
      <h2 class="text-3xl sm:text-4xl font-bold text-zinc-900 mt-4">Edremit Merkez Pilot Garage Farkı</h2>
      <p class="mt-3 text-zinc-600">Modern teknoloji, sertifikalı süreç ve tarafsız raporlama.</p>
    </div>

    <article class="relative bg-gradient-to-br from-purple-50 via-violet-50 to-fuchsia-50 border-2 border-purple-200 rounded-2xl p-6 sm:p-8 mb-6 overflow-hidden shadow-xl shadow-purple-100">
      <div class="absolute -top-12 -right-12 w-48 h-48 bg-purple-200/40 rounded-full blur-3xl"></div>
      <div class="absolute -bottom-12 -left-12 w-48 h-48 bg-fuchsia-200/40 rounded-full blur-3xl"></div>

      <div class="relative flex flex-col md:flex-row items-start gap-6">
        <div class="flex-shrink-0">
          <div class="w-20 h-20 sm:w-24 sm:h-24 bg-gradient-to-br from-purple-500 to-fuchsia-600 rounded-2xl flex items-center justify-center text-white shadow-lg shadow-purple-500/40">
            <div class="w-12 h-12 sm:w-14 sm:h-14" set:html={icons.uv} />
          </div>
        </div>
        <div class="flex-1">
          <div class="inline-flex items-center gap-1.5 px-2.5 py-1 bg-purple-600 text-white text-xs font-bold rounded-full mb-3">
            <span class="w-1.5 h-1.5 bg-white rounded-full animate-pulse"></span>
            {featured.badge}
          </div>
          <h3 class="text-2xl sm:text-3xl font-bold text-zinc-900">{featured.title}</h3>
          <p class="mt-3 text-zinc-700 text-base sm:text-lg leading-relaxed">{featured.description}</p>
          <div class="mt-4 flex flex-wrap gap-2 text-xs">
            <span class="px-2 py-1 bg-white text-purple-700 font-semibold rounded border border-purple-200">Gözle Görülmeyen İzler</span>
            <span class="px-2 py-1 bg-white text-purple-700 font-semibold rounded border border-purple-200">Boya Onarım Tespiti</span>
            <span class="px-2 py-1 bg-white text-purple-700 font-semibold rounded border border-purple-200">Profesyonel UV Lambası</span>
          </div>
        </div>
      </div>
    </article>

    <div class="grid sm:grid-cols-2 lg:grid-cols-5 gap-4">
      {others.map(usp => (
        <article class="group bg-white border border-zinc-200 hover:border-red-200 hover:shadow-lg rounded-xl p-5 transition-all hover:-translate-y-1">
          <div class="w-11 h-11 bg-red-50 group-hover:bg-red-100 text-red-600 rounded-lg flex items-center justify-center mb-3 transition-colors">
            <div class="w-6 h-6" set:html={icons[usp.icon] || icons.star} />
          </div>
          <h3 class="font-bold text-zinc-900 text-base">{usp.title}</h3>
          <p class="mt-1 text-sm text-zinc-600 leading-relaxed">{usp.description}</p>
        </article>
      ))}
    </div>
  </div>
</section>
