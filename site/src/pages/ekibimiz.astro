---
import BaseLayout from '../layouts/BaseLayout.astro';
import business from '../data/business.json';

const team = business.team ?? [];
const lead = team[0];

const waUrl = `https://wa.me/${business.whatsapp.replace('+','')}?text=${encodeURIComponent(business.whatsappMessage)}`;
---
<BaseLayout title="Ekibimiz" description="Edremit Merkez Pilot Garage ekibi — TSE belgeli, MEB ustalık belgeli, yetkili servis tecrübeli uzman teknisyenler. Oto ekspertizi güvenle bize bırakın.">

  {/* HERO — sade kurumsal */}
  <section class="bg-white border-b border-zinc-200">
    <div class="max-w-6xl mx-auto px-6 py-14 sm:py-20">
      <div class="text-[11px] uppercase tracking-[0.22em] text-red-600 font-semibold mb-3">Ekibimiz</div>
      <h1 class="font-display text-3xl sm:text-5xl font-bold text-zinc-900 tracking-tight leading-tight">
        Doğru rapor, <span class="text-red-600">deneyimli ellerden</span>.
      </h1>
      <p class="mt-5 text-base sm:text-lg text-zinc-600 max-w-3xl leading-relaxed">
        Edremit Merkez Pilot Garage ekibi; yetkili servis geçmişi, MEB ustalık belgesi ve marka eğitimleri ile donanmış teknisyenlerden oluşur. Aracınız hakkında karar verirken arkasında duran rapor — alanında yetişmiş insanların imzasını taşır.
      </p>
    </div>
  </section>

  {/* LEAD — Kazım TÜRKER detaylı kart */}
  {lead && (
    <section class="bg-stone-50 border-b border-zinc-200">
      <div class="max-w-6xl mx-auto px-6 py-14 sm:py-20">
        <div class="grid lg:grid-cols-12 gap-8 lg:gap-12 items-start">

          {/* Sol — Fotoğraf */}
          <div class="lg:col-span-5">
            <div class="relative">
              <img src={lead.image} alt={lead.name} class="w-full aspect-[4/5] object-cover rounded shadow-lg ring-1 ring-zinc-200" />
              <div class="absolute -top-2 -right-2 bg-red-600 text-white text-[10px] uppercase tracking-[0.2em] font-bold px-3 py-1.5 rounded-sm shadow-md">
                Kıdemli Usta
              </div>
            </div>
          </div>

          {/* Sağ — Bilgiler */}
          <div class="lg:col-span-7">
            <div class="text-[11px] uppercase tracking-[0.22em] text-zinc-500 font-semibold mb-2">{lead.specialty}</div>
            <h2 class="font-display text-3xl sm:text-4xl font-bold text-zinc-900 tracking-tight">{lead.name}</h2>
            <div class="mt-1 text-base text-red-600 font-medium">{lead.role}</div>
            {lead.origin && <div class="mt-2 text-sm text-zinc-500">{lead.origin}</div>}

            <p class="mt-6 text-base text-zinc-700 leading-relaxed">{lead.bio}</p>

            {/* Marka geçmişi */}
            {lead.careerBrands && lead.careerBrands.length > 0 && (
              <div class="mt-7">
                <div class="text-[11px] uppercase tracking-[0.18em] text-zinc-500 font-semibold mb-3">Yetkili Servis Geçmişi</div>
                <div class="flex flex-wrap gap-2">
                  {lead.careerBrands.map(brand => (
                    <span class="inline-flex items-center px-3 py-1.5 bg-white border border-zinc-300 text-zinc-800 text-sm font-medium rounded">
                      {brand}
                    </span>
                  ))}
                </div>
              </div>
            )}

            {/* Belge ve sertifikalar */}
            {lead.credentials && lead.credentials.length > 0 && (
              <div class="mt-8">
                <div class="text-[11px] uppercase tracking-[0.18em] text-zinc-500 font-semibold mb-4">Belgeler & Eğitimler</div>
                <ul class="space-y-3">
                  {lead.credentials.map(c => (
                    <li class="flex gap-4 p-4 bg-white border border-zinc-200 rounded">
                      <div class="flex-shrink-0 w-12 h-12 bg-red-50 border border-red-200 rounded flex items-center justify-center">
                        <span class="text-red-600 font-display font-bold text-xs tracking-wider">{c.tag}</span>
                      </div>
                      <div class="flex-1 min-w-0">
                        <div class="font-semibold text-zinc-900 text-sm">{c.label}</div>
                        <div class="text-xs text-zinc-600 mt-0.5">{c.issuer}</div>
                        <div class="text-xs text-zinc-500 mt-1 flex items-center gap-3">
                          <span>{c.field}</span>
                          <span class="text-zinc-300">·</span>
                          <span class="font-medium">{c.year}</span>
                        </div>
                      </div>
                    </li>
                  ))}
                </ul>
              </div>
            )}
          </div>
        </div>
      </div>
    </section>
  )}

  {/* DİĞER EKİP — CV bekleyenler için placeholder */}
  <section class="bg-white border-b border-zinc-200">
    <div class="max-w-6xl mx-auto px-6 py-14 sm:py-20">
      <div class="text-center mb-10">
        <div class="text-[11px] uppercase tracking-[0.22em] text-red-600 font-semibold mb-2">Diğer Teknisyenlerimiz</div>
        <h2 class="font-display text-2xl sm:text-3xl font-bold text-zinc-900">Tam Kadromuz Yakında</h2>
        <p class="mt-3 text-zinc-600 max-w-2xl mx-auto">Ekibimizin diğer üyelerinin detaylı profilleri ve uzmanlık alanları kısa süre içinde eklenecektir.</p>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {[1, 2, 3].map(i => (
          <div class="border border-zinc-200 rounded p-6 bg-stone-50">
            <div class="w-16 h-16 bg-zinc-200 rounded-full flex items-center justify-center mb-4">
              <svg class="w-8 h-8 text-zinc-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 9a3 3 0 100-6 3 3 0 000 6zm-7 9a7 7 0 1114 0H3z" clip-rule="evenodd"/></svg>
            </div>
            <div class="font-semibold text-zinc-700">Teknisyen Profili</div>
            <div class="text-sm text-zinc-500 mt-1">Detaylar yakında</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  {/* CTA — sade */}
  <section class="bg-zinc-50">
    <div class="max-w-4xl mx-auto px-6 py-14 sm:py-16 text-center">
      <h2 class="font-display text-2xl sm:text-3xl font-bold text-zinc-900">Aracınız için randevu oluşturmak ister misiniz?</h2>
      <p class="mt-3 text-zinc-600">Telefon veya WhatsApp üzerinden ekibimize ulaşın.</p>
      <div class="mt-7 flex flex-col sm:flex-row justify-center gap-3 max-w-md mx-auto">
        <a href={`tel:${business.phoneE164}`} class="flex-1 inline-flex items-center justify-center gap-2 px-6 py-3 bg-red-600 hover:bg-red-700 text-white font-semibold rounded transition-colors">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z"/></svg>
          {business.phone}
        </a>
        <a href={waUrl} target="_blank" rel="noopener" class="flex-1 inline-flex items-center justify-center gap-2 px-6 py-3 bg-green-600 hover:bg-green-700 text-white font-semibold rounded transition-colors">
          WhatsApp ile Yaz
        </a>
      </div>
    </div>
  </section>

</BaseLayout>
