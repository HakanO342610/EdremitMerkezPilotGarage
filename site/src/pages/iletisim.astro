---
import BaseLayout from '../layouts/BaseLayout.astro';
import business from '../data/business.json';

const waUrl = `https://wa.me/${business.whatsapp.replace('+','')}?text=${encodeURIComponent(business.whatsappMessage)}`;
---
<BaseLayout title="İletişim ve Konum" description="Edremit Merkez Pilot Garage iletişim bilgileri. Edremit 5. Noterliği karşısında, telefon: 0532 306 30 10, WhatsApp ile hızlı randevu.">

  <section class="bg-white border-b border-zinc-200">
    <div class="max-w-6xl mx-auto px-6 py-14 sm:py-20">
      <div class="text-[11px] uppercase tracking-[0.22em] text-red-600 font-semibold mb-3">İletişim ve Konum</div>
      <h1 class="font-display text-3xl sm:text-5xl font-bold text-zinc-900 tracking-tight leading-tight">
        Edremit 5. Noter'in <span class="text-red-600">tam karşısındayız</span>.
      </h1>
      <p class="mt-5 text-base sm:text-lg text-zinc-600 max-w-3xl leading-relaxed">
        Sıra beklemeden, 1 dakika içinde notere ulaşabilirsiniz.
      </p>
    </div>
  </section>

  <section class="max-w-6xl mx-auto px-4 sm:px-6 py-12 sm:py-16 grid lg:grid-cols-2 gap-10">

    <div>
      <h2 class="text-2xl font-bold text-zinc-900 mb-6">Bize Ulaşın</h2>

      <div class="space-y-4">
        <a href={`tel:${business.phoneE164}`} class="flex items-center gap-4 p-5 bg-white border border-zinc-200 hover:border-red-300 hover:shadow-md rounded-xl transition-all group">
          <div class="w-12 h-12 bg-red-100 text-red-600 rounded-lg flex items-center justify-center text-xl group-hover:bg-red-600 group-hover:text-white transition-colors">📞</div>
          <div class="flex-1">
            <div class="text-xs text-zinc-500 uppercase tracking-wider">Telefon</div>
            <div class="text-lg font-bold text-zinc-900">{business.phone}</div>
          </div>
          <span class="text-zinc-400 group-hover:text-red-600">→</span>
        </a>

        <a href={waUrl} target="_blank" rel="noopener" class="flex items-center gap-4 p-5 bg-white border border-zinc-200 hover:border-green-300 hover:shadow-md rounded-xl transition-all group">
          <div class="w-12 h-12 bg-green-100 text-green-600 rounded-lg flex items-center justify-center text-xl group-hover:bg-green-600 group-hover:text-white transition-colors">💬</div>
          <div class="flex-1">
            <div class="text-xs text-zinc-500 uppercase tracking-wider">WhatsApp</div>
            <div class="text-lg font-bold text-zinc-900">{business.phone}</div>
            <div class="text-xs text-zinc-500 mt-0.5">Mesajla randevu alın</div>
          </div>
          <span class="text-zinc-400 group-hover:text-green-600">→</span>
        </a>

        <a href={`mailto:${business.email}`} class="flex items-center gap-4 p-5 bg-white border border-zinc-200 hover:border-red-300 hover:shadow-md rounded-xl transition-all group">
          <div class="w-12 h-12 bg-zinc-100 text-zinc-600 rounded-lg flex items-center justify-center text-xl group-hover:bg-zinc-900 group-hover:text-white transition-colors">✉</div>
          <div class="flex-1 min-w-0">
            <div class="text-xs text-zinc-500 uppercase tracking-wider">E-mail</div>
            <div class="text-base font-bold text-zinc-900 break-all">{business.email}</div>
          </div>
          <span class="text-zinc-400 group-hover:text-zinc-900">→</span>
        </a>

        <a href={business.googleMapsUrl} target="_blank" rel="noopener" class="flex items-center gap-4 p-5 bg-white border border-zinc-200 hover:border-red-300 hover:shadow-md rounded-xl transition-all group">
          <div class="w-12 h-12 bg-red-100 text-red-600 rounded-lg flex items-center justify-center text-xl group-hover:bg-red-600 group-hover:text-white transition-colors">📍</div>
          <div class="flex-1">
            <div class="text-xs text-zinc-500 uppercase tracking-wider">Adres</div>
            <div class="text-base font-bold text-zinc-900">{business.addressLine}</div>
            <div class="text-sm text-zinc-600">{business.city}, {business.region}</div>
          </div>
          <span class="text-zinc-400 group-hover:text-red-600">→</span>
        </a>
      </div>

      <div class="mt-8 bg-zinc-50 border border-zinc-200 rounded-xl p-5">
        <h3 class="font-bold text-zinc-900 mb-3">Çalışma Saatleri</h3>
        <ul class="space-y-1.5 text-sm text-zinc-700">
          <li class="flex justify-between"><span>Pazartesi - Cumartesi</span><span class="font-semibold">08:30 - 18:30</span></li>
          <li class="flex justify-between text-zinc-500"><span>Pazar</span><span class="font-semibold">Kapalı</span></li>
        </ul>
      </div>
    </div>

    <div>
      <h2 class="text-2xl font-bold text-zinc-900 mb-6">Konumumuz</h2>
      <div class="relative aspect-square rounded-xl overflow-hidden shadow-lg border border-zinc-200">
        <iframe
          src={business.googleMapsEmbed}
          class="absolute inset-0 w-full h-full border-0"
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="Edremit Merkez Pilot Garage Konum"
          allowfullscreen
        ></iframe>
      </div>
      <a href={business.googleMapsUrl} target="_blank" rel="noopener" class="mt-4 inline-flex items-center gap-2 text-red-600 hover:text-red-700 font-semibold">
        🧭 Google Haritalar'da Yol Tarifi Al →
      </a>
    </div>
  </section>

</BaseLayout>
