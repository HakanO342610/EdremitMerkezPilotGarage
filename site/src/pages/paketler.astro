---
import BaseLayout from '../layouts/BaseLayout.astro';
import business from '../data/business.json';
import packages from '../data/packages.json';

const waUrl = `https://wa.me/${business.whatsapp.replace('+','')}?text=${encodeURIComponent(business.whatsappMessage)}`;

const pkgs = packages.packages ?? [];
const featuredId = pkgs.find((p: any) => p.featured)?.id;
---
<BaseLayout title="Oto Ekspertiz Paketleri ve Fiyatları 2026" description="Edremit Merkez Pilot Garage oto ekspertiz paketleri: Black Box (640 nokta) 17.500₺'den başlayan fiyatlarla. 10 paket seçeneği, kurumsal fiyat listesi.">

  <h1 class="sr-only">Pilot Garage Edremit — Oto Ekspertiz Fiyat Listesi 2026</h1>

  {/* HERO — sade kurumsal */}
  <section class="bg-white border-b border-zinc-200">
    <div class="max-w-6xl mx-auto px-6 py-14 sm:py-20">
      <div class="text-[11px] uppercase tracking-[0.22em] text-red-600 font-semibold mb-3">Paketler & Fiyatlar</div>
      <h2 class="font-display text-3xl sm:text-5xl font-bold text-zinc-900 tracking-tight leading-tight">
        Oto Ekspertiz <span class="text-red-600">Fiyatları 2026</span>.
      </h2>
      <p class="mt-5 text-base sm:text-lg text-zinc-600 max-w-3xl leading-relaxed">
        Pilot Garage kurumsal fiyat listesi. <strong class="text-zinc-900">10 farklı paket</strong> — aracınızın ihtiyacına göre 7 noktadan 640 noktaya kadar inceleme. Detayları görmek için paketlere tıklayın.
      </p>
      <p class="mt-4 text-xs text-zinc-500 italic">{packages.note}</p>
    </div>
  </section>

  {/* PAKETLER GRID */}
  <section class="bg-stone-50 border-b border-zinc-200">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 py-12 sm:py-16">

      <div class="grid md:grid-cols-2 gap-5 sm:gap-6">
        {pkgs.map((p: any, idx: number) => (
          <article class={`group relative bg-white border rounded overflow-hidden shadow-sm hover:shadow-md transition-all flex flex-col ${p.featured ? 'border-red-500 ring-1 ring-red-500/20 md:col-span-2' : 'border-zinc-200 hover:border-red-300'}`}>

            {p.featured && (
              <div class="absolute top-0 right-0 bg-red-600 text-white text-[10px] uppercase tracking-[0.2em] font-bold px-3 py-1.5 rounded-bl">En Kapsamlı</div>
            )}
            {p.popular && (
              <div class="absolute top-0 right-0 bg-zinc-900 text-white text-[10px] uppercase tracking-[0.2em] font-bold px-3 py-1.5 rounded-bl">Popüler</div>
            )}

            {/* Üst — başlık + fiyat */}
            <div class={`p-6 sm:p-7 border-b border-zinc-100 ${p.featured ? 'bg-gradient-to-br from-red-50 to-white' : ''}`}>
              <div class="text-[10px] uppercase tracking-[0.22em] text-red-600 font-semibold mb-2">Paket {String(idx+1).padStart(2,'0')}</div>
              <h3 class="font-display text-xl sm:text-2xl font-bold text-zinc-900 tracking-tight leading-tight">{p.name}</h3>
              <div class="mt-3 flex items-baseline gap-2">
                <span class="font-display text-3xl sm:text-4xl font-bold text-zinc-900">{p.priceDisplay}</span>
                <span class="text-xl text-zinc-700 font-semibold">₺</span>
                <span class="text-xs text-zinc-500 ml-1">{p.points > 0 ? `${p.points} nokta` : 'özel'}</span>
              </div>
              <p class="mt-3 text-sm text-zinc-600 leading-relaxed line-clamp-4">{p.description}</p>
            </div>

            {/* Orta — accordion */}
            {p.categories && p.categories.length > 0 && (
              <details class="group/det border-b border-zinc-100">
                <summary class="cursor-pointer list-none px-6 py-4 flex items-center justify-between bg-zinc-50 hover:bg-zinc-100 transition-colors">
                  <span class="font-semibold text-sm text-zinc-800">
                    Paket Özellikleri <span class="text-red-600 font-numeric">({p.points} Nokta)</span>
                  </span>
                  <svg class="w-4 h-4 text-zinc-500 transition-transform group-open/det:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                  </svg>
                </summary>

                <div class="px-6 py-4 space-y-2 max-h-[480px] overflow-y-auto">
                  {p.categories.map((cat: any) => (
                    <details class="group/cat border border-zinc-200 rounded overflow-hidden">
                      <summary class="cursor-pointer list-none px-4 py-2.5 flex items-center justify-between bg-white hover:bg-red-50 transition-colors">
                        <span class="text-sm text-zinc-800">
                          <span class="font-numeric text-red-600 font-bold">({cat.count})</span>
                          <span class="ml-1.5 font-medium">{cat.name}</span>
                        </span>
                        <svg class="w-3.5 h-3.5 text-zinc-400 transition-transform group-open/cat:rotate-180 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                        </svg>
                      </summary>
                      <ul class="px-4 py-3 bg-stone-50 border-t border-zinc-200 space-y-1.5">
                        {cat.items.map((it: string) => (
                          <li class="text-xs text-zinc-700 flex items-start gap-2 leading-relaxed">
                            <span class="text-red-500 mt-1 shrink-0">●</span>
                            <span>{it}</span>
                          </li>
                        ))}
                      </ul>
                    </details>
                  ))}
                </div>
              </details>
            )}

            {/* Alt — CTA */}
            <div class="mt-auto p-5 sm:p-6 flex flex-col sm:flex-row gap-2 bg-white">
              <a href={`tel:${business.phoneE164}`} class="flex-1 inline-flex items-center justify-center gap-2 px-4 py-2.5 bg-red-600 hover:bg-red-700 text-white text-sm font-semibold rounded transition-colors">
                Randevu Al
              </a>
              <a href={waUrl} target="_blank" rel="noopener" class="flex-1 inline-flex items-center justify-center gap-2 px-4 py-2.5 bg-white border border-zinc-300 hover:border-red-500 text-zinc-800 hover:text-red-600 text-sm font-semibold rounded transition-colors">
                WhatsApp
              </a>
            </div>
          </article>
        ))}
      </div>

      {/* Alt not — kupon bilgisi */}
      <div class="mt-8 p-5 bg-zinc-50 border-l-4 border-red-500 rounded text-sm text-zinc-700 leading-relaxed">
        <strong class="text-zinc-900">İndirim Kuponu Notu:</strong> Pilot Garage mobil uygulamasından veya önceki ekspertiz hizmetlerinden kazanılan indirim kuponları yalnızca <strong>Black Box, First Class, Business ve Bold Class</strong> paketlerinde kullanılabilmektedir. Daha düşük seviyedeki paketlerde indirim kuponları geçerli değildir.
      </div>
    </div>
  </section>

  {/* KARAR YARDIMI — mevcut korundu */}
  <section class="relative overflow-hidden bg-gradient-to-br from-zinc-100 via-zinc-50 to-red-50 py-16 sm:py-20">
    <div class="absolute inset-0 opacity-30" style="background-image: radial-gradient(circle at 50% 0%, rgba(220,38,38,0.15) 0%, transparent 60%);"></div>
    <div class="relative max-w-4xl mx-auto px-4 sm:px-6 text-center">
      <div class="inline-block px-3 py-1 bg-red-100 text-red-700 text-xs font-bold uppercase tracking-[0.18em] rounded-full mb-4">Karar Veremediyseniz</div>
      <h2 class="font-display text-3xl sm:text-5xl font-bold tracking-tighter leading-[0.95]" style="text-shadow: 0 1px 0 rgba(255,255,255,0.8), 0 2px 4px rgba(0,0,0,0.08);">
        Hangi <span class="text-3d-red">Paketi</span> Seçmeliyim?
      </h2>
      <p class="mt-5 text-zinc-600 text-base sm:text-lg max-w-2xl mx-auto">Aracınız ve ihtiyaçlarınız hakkında bilgi verin, size en uygun paketi <strong class="text-zinc-900">ücretsiz olarak</strong> önerelim.</p>
      <div class="mt-8 flex flex-col sm:flex-row justify-center gap-3 max-w-md mx-auto">
        <a href={`tel:${business.phoneE164}`} class="flex-1 inline-flex items-center justify-center gap-2 px-6 py-3.5 bg-red-600 hover:bg-red-700 text-white font-semibold rounded-md transition-colors shadow-lg shadow-red-600/30">📞 {business.phone}</a>
        <a href={waUrl} target="_blank" rel="noopener" class="flex-1 inline-flex items-center justify-center gap-2 px-6 py-3.5 bg-green-600 hover:bg-green-700 text-white font-semibold rounded-md transition-colors shadow-lg shadow-green-600/30">💬 WhatsApp</a>
      </div>
    </div>
  </section>

</BaseLayout>
